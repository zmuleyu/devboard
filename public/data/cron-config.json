{
  "offPeakWindow": {
    "start": "01:00",
    "end": "07:00"
  },
  "defaultModel": "sonnet",
  "alerts": {
    "toast": {
      "enabled": true
    },
    "webhook": {
      "enabled": false,
      "url": "",
      "onlyOnFail": true,
      "headers": {}
    },
    "devboard": {
      "enabled": true,
      "recentFailuresCount": 10
    },
    "escalation": {
      "consecutiveFailThreshold": 3,
      "action": "webhook"
    }
  },
  "projects": [
    {
      "name": "ai_projects",
      "direction": "web",
      "managementName": "web-legislation",
      "path": "D:/projects/cybernium/ai_projects",
      "type": "js",
      "pkgManager": "pnpm",
      "mainBranch": "dev",
      "tscCmd": "pnpm tsc --noEmit",
      "testCmd": "pnpm test",
      "auditCmd": "pnpm audit --json",
      "coverageCmd": "pnpm test -- --coverage --coverageReporters=json-summary 2>/dev/null || pnpm test"
    },
    {
      "name": "pixel-herbarium",
      "direction": "app",
      "managementName": "app-herbarium",
      "path": "D:/projects/Games/gardern/pixel-herbarium",
      "type": "js",
      "pkgManager": "npm",
      "mainBranch": "master",
      "tscCmd": "npx tsc --noEmit",
      "testCmd": "npm test",
      "auditCmd": "npm audit --json",
      "coverageCmd": "npm test -- --coverage --coverageReporters=json-summary 2>/dev/null || npm test"
    },
    {
      "name": "scrapling-mcp",
      "direction": "tool",
      "managementName": "tool-scrapling",
      "path": "D:/projects/Others/scrapling-mcp",
      "type": "python",
      "mainBranch": "main",
      "testCmd": "pytest -x --tb=short",
      "coverageCmd": "pytest --cov --cov-report=term-missing -q 2>/dev/null || pytest -x --tb=short"
    },
    {
      "name": "Data_management",
      "direction": "tool",
      "managementName": "tool-data-mgmt",
      "path": "D:/projects/Others/Data_management",
      "type": "js",
      "pkgManager": "npm",
      "mainBranch": "master",
      "tscCmd": "npx tsc --noEmit",
      "testCmd": "npm test",
      "auditCmd": "npm audit --json",
      "coverageCmd": "npm test -- --coverage --coverageReporters=json-summary 2>/dev/null || npm test"
    },
    {
      "name": "ziyou-server",
      "direction": "tool",
      "managementName": "tool-ziyou-server",
      "path": "D:/projects/ziyou-assistant/ziyou-server",
      "type": "python",
      "mainBranch": "master",
      "testCmd": "pytest -x --tb=short"
    },
    {
      "name": "devboard",
      "direction": "archived",
      "managementName": "archived-devboard",
      "path": "D:/projects/devboard",
      "type": "js",
      "pkgManager": "npm",
      "mainBranch": "master",
      "tscCmd": "npx tsc --noEmit",
      "auditCmd": "npm audit --json"
    }
  ],
  "workflows": [
    {
      "name": "nightly-patrol",
      "description": "Nightly code quality patrol + backup",
      "steps": [
        {
          "task": "patrol",
          "onFail": "continue"
        },
        {
          "task": "guard-backup",
          "parallel": true
        }
      ]
    },
    {
      "name": "weekly-maintenance",
      "description": "Sunday: audit + cleanup + coverage",
      "steps": [
        {
          "task": "dependency-check"
        },
        {
          "task": "stale-branch-cleanup",
          "parallel": true
        },
        {
          "task": "coverage-report"
        }
      ]
    },
    {
      "name": "monday-reports",
      "description": "Monday: changelog + audit + PR review",
      "steps": [
        {
          "task": "changelog-gen"
        },
        {
          "task": "guard-audit",
          "parallel": true
        },
        {
          "task": "pr-review"
        }
      ]
    }
  ],
  "tasks": [
    {
      "name": "tsc-check",
      "schedulerName": "TSC-ai_projects",
      "prompt": "prompts/tsc-check.txt",
      "schedule": "09:07",
      "tools": "Bash,Read",
      "maxTurns": 8,
      "budget": "0.15",
      "timeLimit": 45,
      "description": "TypeScript check for ai_projects"
    },
    {
      "name": "patrol",
      "prompt": "prompts/patrol.txt",
      "schedule": "02:00",
      "tools": "Bash,Read,Grep,Glob",
      "maxTurns": 15,
      "budget": "0.50",
      "timeLimit": 70,
      "description": "Full project TSC + test + lint patrol",
      "onFailure": "notify"
    },
