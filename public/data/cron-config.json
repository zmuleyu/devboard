{
  "offPeakWindow": {
    "start": "01:00",
    "end": "07:00"
  },
  "defaultModel": "sonnet",
  "alerts": {
    "toast": { "enabled": true },
    "webhook": {
      "enabled": false,
      "url": "",
      "onlyOnFail": true,
      "headers": {}
    },
    "devboard": { "enabled": true, "recentFailuresCount": 10 },
    "escalation": {
      "consecutiveFailThreshold": 3,
      "action": "webhook"
    }
  },
  "projects": [
    {
      "name": "ai_projects",
      "path": "D:/projects/cybernium/ai_projects",
      "type": "js",
      "pkgManager": "pnpm",
      "mainBranch": "dev",
      "tscCmd": "pnpm tsc --noEmit",
      "testCmd": "pnpm test",
      "auditCmd": "pnpm audit --json",
      "coverageCmd": "pnpm test -- --coverage --coverageReporters=json-summary 2>/dev/null || pnpm test"
    },
    {
      "name": "pixel-herbarium",
      "path": "D:/projects/Games/gardern/pixel-herbarium",
      "type": "js",
      "pkgManager": "npm",
      "mainBranch": "master",
      "tscCmd": "npx tsc --noEmit",
      "testCmd": "npm test",
      "auditCmd": "npm audit --json",
      "coverageCmd": "npm test -- --coverage --coverageReporters=json-summary 2>/dev/null || npm test"
    },
    {
      "name": "scrapling-mcp",
      "path": "D:/projects/Others/scrapling-mcp",
      "type": "python",
      "mainBranch": "main",
      "testCmd": "pytest -x --tb=short",
      "coverageCmd": "pytest --cov --cov-report=term-missing -q 2>/dev/null || pytest -x --tb=short"
    },
    {
      "name": "Data_management",
      "path": "D:/projects/Others/Data_management",
      "type": "js",
      "pkgManager": "npm",
      "mainBranch": "master",
      "tscCmd": "npx tsc --noEmit",
      "testCmd": "npm test",
      "auditCmd": "npm audit --json",
      "coverageCmd": "npm test -- --coverage --coverageReporters=json-summary 2>/dev/null || npm test"
    },
    {
      "name": "ziyou-server",
      "path": "D:/projects/ziyou-assistant/ziyou-server",
      "type": "python",
      "mainBranch": "master",
      "testCmd": "pytest -x --tb=short"
    },
    {
      "name": "devboard",
      "path": "D:/projects/devboard",
      "type": "js",
      "pkgManager": "npm",
      "mainBranch": "master",
      "tscCmd": "npx tsc --noEmit",
      "auditCmd": "npm audit --json"
    }
  ],
  "workflows": [
    {
      "name": "nightly-patrol",
      "description": "Nightly code quality patrol + backup",
      "steps": [
        {
          "task": "patrol",
          "onFail": "continue"
        },
        {
          "task": "guard-backup",
          "parallel": true
        }
      ]
    },
    {
      "name": "weekly-maintenance",
      "description": "Sunday: audit + cleanup + coverage",
      "steps": [
        {
          "task": "dependency-check"
        },
        {
          "task": "stale-branch-cleanup",
          "parallel": true
        },
        {
          "task": "coverage-report"
        }
      ]
    },
    {
      "name": "monday-reports",
      "description": "Monday: changelog + audit + PR review",
      "steps": [
        {
          "task": "changelog-gen"
        },
        {
          "task": "guard-audit",
          "parallel": true
        },
        {
          "task": "pr-review"
        }
      ]
    }
  ],
  "tasks": [
    {
      "name": "tsc-check",
      "schedulerName": "TSC-ai_projects",
      "prompt": "prompts/tsc-check.txt",
      "schedule": "09:07",
      "tools": "Bash,Read",
      "maxTurns": 8,
      "description": "TypeScript check for ai_projects"
    },
    {
      "name": "patrol",
      "prompt": "prompts/patrol.txt",
      "schedule": "02:00",
      "tools": "Bash,Read,Grep,Glob",
      "maxTurns": 15,
      "description": "Full project TSC + test + lint patrol"
    },
    {
      "name": "data-sync",
      "prompt": "prompts/data-sync.txt",
      "schedule": "05:30",
      "tools": "Bash,Read,Write,Grep,Glob",
      "maxTurns": 8,
      "description": "DevBoard API sync (ai_projects) + daily report"
    },
    {
      "name": "pr-review",
      "schedulerName": "PRReview",
      "prompt": "prompts/pr-review.txt",
      "schedule": "03:00",
      "scheduleDays": "1,3,5",
      "tools": "Bash,Read,Grep,Glob",
      "maxTurns": 10,
      "description": "Auto review open PRs (Mon/Wed/Fri)"
    },
    {
      "name": "guard-backup",
      "prompt": "prompts/guard-backup.txt",
      "schedule": "04:00",
      "tools": "Bash,Read",
      "maxTurns": 5,
      "description": "Daily claude-guard backup of Claude Code assets"
    },
    {
      "name": "guard-audit",
      "prompt": "prompts/guard-audit.txt",
      "schedule": "08:30",
      "scheduleDays": "1",
      "tools": "Bash,Read",
      "maxTurns": 5,
      "description": "Weekly account health audit (Monday)"
    },
    {
      "name": "ph-monitor",
      "schedulerName": "PHMonitor",
      "prompt": "prompts/ph-monitor.txt",
      "schedule": "10:00",
      "scheduleDays": "0",
      "tools": "Bash,Read,Write",
      "maxTurns": 12,
      "budget": "0.80",
      "description": "Weekly PH competitor review collection + signal classification (Sunday + hanami Mon/Wed Mar-May)"
    },
    {
      "name": "batch-fix",
      "prompt": "prompts/batch-fix.txt",
      "schedule": "manual",
      "tools": "Bash,Read,Write,Edit,Grep,Glob",
      "maxTurns": 20,
      "description": "Manual batch code modifications"
    },
    {
      "name": "dependency-check",
      "prompt": "prompts/dependency-check.txt",
      "schedule": "03:00",
      "scheduleDays": "0",
      "tools": "Bash,Read",
      "maxTurns": 8,
      "description": "Weekly npm/pnpm audit across JS/TS projects (Sunday)"
    },
    {
      "name": "coverage-report",
      "prompt": "prompts/coverage-report.txt",
      "schedule": "04:00",
      "scheduleDays": "6",
      "tools": "Bash,Read,Grep",
      "maxTurns": 15,
      "description": "Weekly test coverage report (Saturday)"
    },
    {
      "name": "stale-branch-cleanup",
      "prompt": "prompts/stale-branch-cleanup.txt",
      "schedule": "05:00",
      "scheduleDays": "0",
      "tools": "Bash,Read",
      "maxTurns": 6,
      "description": "Weekly merged branch cleanup (Sunday)"
    },
    {
      "name": "changelog-gen",
      "prompt": "prompts/changelog-gen.txt",
      "schedule": "01:00",
      "scheduleDays": "1",
      "tools": "Bash,Read,Write",
      "maxTurns": 15,
      "description": "Weekly changelog summary (Monday)"
    },
    {
      "name": "lobehub-icons-install",
      "schedulerName": "LobeHubIcons",
      "prompt": "prompts/lobehub-icons-install.txt",
      "schedule": "02:30",
      "tools": "Bash,Read,Write,Edit",
      "maxTurns": 20,
      "description": "One-shot: install @lobehub/icons across ecosystem projects"
    },
    {
      "name": "trpc-scaffold",
      "prompt": "prompts/trpc-scaffold.txt",
      "schedule": "03:00",
      "tools": "Bash,Read,Write,Edit",
      "maxTurns": 12,
      "description": "One-shot: set up tRPC scaffold in ai_projects"
    },
    {
      "name": "mcp-health",
      "prompt": "prompts/mcp-health.txt",
      "schedule": "07:30",
      "tools": "Bash,Read,mcp__fetch__fetch,mcp__plugin_github_github__get_me,mcp__supabase__list_tables",
      "maxTurns": 8,
      "description": "Daily MCP server health check"
    },
    {
      "name": "dep-update",
      "prompt": "prompts/dep-update.txt",
      "schedule": "03:30",
      "scheduleDays": "3",
      "tools": "Bash,Read",
      "maxTurns": 10,
      "description": "Weekly dependency update scan — flag outdated packages by severity (Wednesday)"
    },
    {
      "name": "portfolio-digest",
      "prompt": "prompts/portfolio-digest.txt",
      "schedule": "06:00",
      "scheduleDays": "0",
      "tools": "Bash,Read,Write",
      "maxTurns": 12,
      "description": "Weekly development digest — cron stats, token usage, project activity (Sunday)"
    },
    {
      "name": "mypy-check",
      "prompt": "prompts/mypy-check.txt",
      "schedule": "02:30",
      "scheduleDays": "0",
      "tools": "Bash,Read",
      "maxTurns": 6,
      "description": "Weekly Python type check with mypy (Sunday)"
    },
    {
      "name": "content-freshness",
      "prompt": "prompts/content-freshness.txt",
      "schedule": "09:00",
      "scheduleDays": "1",
      "tools": "Bash,Read",
      "maxTurns": 8,
      "description": "Weekly content freshness scan — flag stale docs >30 days (Monday)"
    }
  ]
}
